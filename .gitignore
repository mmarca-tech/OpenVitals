#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
# Gradle writes build outputs under android/build/ and android/app/build/ too, which the
# root-anchored /build/ above does not cover -- two artifacts were committed by accident
# before this line existed (see the commit that removes them).
**/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
debug-screenshots/
.claude/
# Keystore / signing
*.jks
*.keystore
*.p12
*.pfx
*.pkcs12
keystore.properties
.woodpecker/*.env
.woodpecker/secrets/
.woodpecker/tmp/

# Local release helpers
.env
.env.local

# Stray crash dumps
Error in OpenVitals *.txt

# Gradle/Kotlin leftovers. The Kotlin app lived at the repo root, so a stray Gradle
# invocation here (or an old checkout) leaves these behind; Flutter's own Android
# build stays under android/ and /build/.
/.gradle/
/.kotlin/
/local.properties
/app/build/
# Gradle writes build outputs under android/build/ and android/app/build/ too, which the
# root-anchored /build/ above does not cover -- two artifacts were committed by accident
# before this line existed (see the commit that removes them).
**/build/
/captures/
test_objects/

# Design-system reference bundle (React/TS UI kit). Kept on disk as a design
# reference, but not versioned in the app repo -- the Kotlin repo gitignored it too.
docs/proposals/OpenVitals Design System/

# Generated localizations. `generate: true` in pubspec means flutter regenerates
# these from lib/l10n/*.arb on every `pub get` / build, so tracking them added
# nothing and made every Weblate pull request unmergeable: Weblate edits the ARBs
# and cannot run gen-l10n, so the committed output was stale by construction.
lib/l10n/app_localizations.dart
lib/l10n/app_localizations_*.dart

# Golden diffs, written by flutter_test on a mismatch. Never committed.
test/goldens/**/failures/
