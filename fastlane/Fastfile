opt_out_usage

default_platform(:android)

OPENVITALS_PACKAGE_NAME = "tech.mmarca.openvitals"
OPENVITALS_METADATA_PATH = "fastlane/metadata/android"

platform :android do
  desc "Upload the signed Android App Bundle directly to Google Play production with store metadata"
  lane :production do |options|
    json_key = options[:json_key] || ENV["GOOGLE_PLAY_JSON_KEY"]
    aab = options[:aab] || ENV["OPENVITALS_RELEASE_AAB"]
    version_code = options[:version_code] || ENV["OPENVITALS_VERSION_CODE"]

    UI.user_error!("json_key is required") if json_key.to_s.empty?
    UI.user_error!("aab is required") if aab.to_s.empty?

    if version_code.to_s.length > 0
      existing_codes = google_play_track_version_codes(
        package_name: OPENVITALS_PACKAGE_NAME,
        json_key: json_key,
        track: "production"
      ).map(&:to_i)

      if existing_codes.include?(version_code.to_i)
        UI.message("Version code #{version_code} is already on Google Play production; skipping production upload.")
        next
      end
    end

    supply(
      package_name: OPENVITALS_PACKAGE_NAME,
      json_key: json_key,
      aab: aab,
      track: "production",
      release_status: "completed",
      metadata_path: OPENVITALS_METADATA_PATH,
      sync_image_upload: true,
      changes_not_sent_for_review: ENV["OPENVITALS_PLAY_CHANGES_NOT_SENT_FOR_REVIEW"] == "true",
      timeout: 600
    )
  end
end
