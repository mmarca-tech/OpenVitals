{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/cards/**",
              "components/charts/**",
              "components/data-display/**",
              "components/forms/**",
              "components/insights/**",
              "components/navigation/**",
              "ui_kits/openvitals-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Roboto|Roboto Mono|Material Symbols Outlined))/i]",
        "message": "Font not provided by the design system. Available: Roboto, Roboto Mono, Material Symbols Outlined."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccentIconChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|color|size|iconSize|style|key|ref|className|style|children)$/]",
        "message": "<AccentIconChip> doesn't accept that prop. Declared props: icon, color, size, iconSize, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AchievementBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|name|requirement|current|target|progress|unlocked|status|accentColor|style|key|ref|className|style|children)$/]",
        "message": "<AchievementBadge> doesn't accept that prop. Declared props: icon, name, requirement, current, target, progress, unlocked, status, accentColor, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomNavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<BottomNavItem> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconPosition|disabled|fullWidth|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconPosition, disabled, fullWidth, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:filled|tonal|outlined|text)$/]",
        "message": "<Button> variant must be one of 'filled' | 'tonal' | 'outlined' | 'text'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:small|medium|large)$/]",
        "message": "<Button> size must be one of 'small' | 'medium' | 'large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='iconPosition'] > Literal[value!=/^(?:leading|trailing)$/]",
        "message": "<Button> iconPosition must be one of 'leading' | 'trailing'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|accentColor|radius|padding|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, accentColor, radius, padding, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|metric|accent|error)$/]",
        "message": "<Card> variant must be one of 'neutral' | 'metric' | 'accent' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:xs|sm|md|lg|xl)$/]",
        "message": "<Card> radius must be one of 'xs' | 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|label|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, disabled, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CrossMetricInsightCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|direction|correlation|relationship|message|pairedDays|accentColor|style|key|ref|className|style|children)$/]",
        "message": "<CrossMetricInsightCard> doesn't accept that prop. Declared props: title, direction, correlation, relationship, message, pairedDays, accentColor, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CrossMetricInsightCard'] > JSXAttribute[name.name='direction'] > Literal[value!=/^(?:positive|negative|flat)$/]",
        "message": "<CrossMetricInsightCard> direction must be one of 'positive' | 'negative' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataConfidenceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|coverage|samples|source|valueKind|warnings|accentColor|style|key|ref|className|style|children)$/]",
        "message": "<DataConfidenceCard> doesn't accept that prop. Declared props: level, coverage, samples, source, valueKind, warnings, accentColor, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataConfidenceCard'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:high|medium|low)$/]",
        "message": "<DataConfidenceCard> level must be one of 'high' | 'medium' | 'low'."
