        "selector": "JSXOpeningElement[name.name='DateNavigator'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|canGoForward|onPrevious|onNext|onOpenCalendar|style|key|ref|className|style|children)$/]",
        "message": "<DateNavigator> doesn't accept that prop. Declared props: title, subtitle, canGoForward, onPrevious, onNext, onOpenCalendar, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DetailRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|style|key|ref|className|style|children)$/]",
        "message": "<DetailRow> doesn't accept that prop. Declared props: label, value, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|weight|fill|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, weight, fill, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|variant|size|disabled|label|onClick|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, variant, size, disabled, label, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:plain|surface)$/]",
        "message": "<IconButton> variant must be one of 'plain' | 'surface'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricBarChart'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|labels|accentColor|height|highlightIndex|max|style|key|ref|className|style|children)$/]",
        "message": "<MetricBarChart> doesn't accept that prop. Declared props: data, labels, accentColor, height, highlightIndex, max, style."
