<?xml version="1.0" encoding="utf-8"?>
<!--
    The 2x1 quick-beverage tile (Add / Edit). Ported 1:1 from the Kotlin
    `res/xml/home_quick_beverage_widget_info.xml`: `android:configure` is the
    dedicated `HomeQuickBeverageWidgetConfigureActivity`, shared with the 1x1
    one-tap tile exactly as Kotlin shared one configuration activity between the
    two. The picker itself is a Flutter screen (the drink catalog lives in drift,
    in Dart) hosted by that activity.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="40dp"
    android:targetCellWidth="2"
    android:targetCellHeight="1"
    android:maxResizeWidth="360dp"
    android:maxResizeHeight="180dp"
    android:updatePeriodMillis="1800000"
    android:description="@string/home_quick_beverage_widget_description"
    android:initialLayout="@layout/glance_default_loading_layout"
    android:configure="tech.mmarca.openvitals.HomeQuickBeverageWidgetConfigureActivity"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:widgetFeatures="reconfigurable" />
