<?xml version="1.0" encoding="utf-8"?>
<!--
    Native-only strings. The app's UI copy lives in Dart (`AppLocalizations`);
    these are the few strings Android itself resolves outside the Flutter engine:
    the home-screen widget picker descriptions, and the fallback text a Glance
    widget renders before Dart's first snapshot push lands.
    Values are copied verbatim from the Kotlin source's `res/values/strings.xml`.
-->
<resources>
    <!-- Widget-picker descriptions (@xml/*_widget_info android:description). -->
    <string name="home_daily_readiness_widget_description">OpenVitals daily readiness</string>
    <string name="home_body_energy_widget_description">OpenVitals body energy</string>
    <string name="home_today_vitals_widget_description">OpenVitals today vitals</string>
    <string name="home_metric_widget_description">OpenVitals metric</string>

    <!-- Widget fallback UI (no snapshot pushed yet). -->
    <string name="home_metric_widget_open_for_details">Open for details</string>
    <!-- The metric tile before it has been configured (the picker's first push
         replaces both). The configuration screen itself is Dart, so its prompt
         lives in the ARB catalogs, not here. -->
    <string name="home_metric_widget_config_title">Choose metric</string>
    <string name="home_metric_widget_not_configured">Select a metric</string>
    <string name="home_widget_today_title">Today</string>
    <string name="home_widget_hrv_short">HRV</string>
    <string name="no_data">No data</string>
    <string name="screen_daily_readiness">Daily Readiness</string>
    <string name="screen_body_energy">Body Energy</string>
    <string name="metric_sleep">Sleep</string>
    <string name="metric_steps">Steps</string>
    <string name="metric_distance">Distance</string>
    <string name="metric_resting_heart_rate">Resting heart rate</string>
    <string name="metric_weekly_cardio_load">Weekly cardio</string>
    <string name="metric_hydration">Beverages</string>
</resources>
