<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- =========================================================================
         Health Connect permissions (ported 1:1 from the Kotlin source manifest).
         The `health` Flutter plugin surfaces these to Health Connect; every type
         the app reads/writes must be declared here or the request is rejected.
         ========================================================================= -->

    <!-- Health Connect permissions - Phase 1 -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.WRITE_STEPS" />
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.WRITE_SLEEP" />
    <!-- Manual-only Health Connect permission; Android ignores standard request-dialog attempts. -->
    <uses-permission android:name="android.permission.health.READ_EXERCISE_ROUTES" />
    <uses-permission android:name="android.permission.health.WRITE_EXERCISE" />
    <uses-permission android:name="android.permission.health.WRITE_EXERCISE_ROUTE" />
    <uses-permission android:name="android.permission.health.WRITE_DISTANCE" />
    <uses-permission android:name="android.permission.health.WRITE_ELEVATION_GAINED" />
    <uses-permission android:name="android.permission.health.WRITE_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.WRITE_TOTAL_CALORIES_BURNED" />

    <!-- Health Connect permissions - Phase 2 -->
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.WRITE_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE" />
    <uses-permission android:name="android.permission.health.WRITE_RESTING_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE_VARIABILITY" />
    <uses-permission android:name="android.permission.health.WRITE_HEART_RATE_VARIABILITY" />
    <uses-permission android:name="android.permission.health.READ_WEIGHT" />
    <uses-permission android:name="android.permission.health.WRITE_WEIGHT" />
    <uses-permission android:name="android.permission.health.READ_HEIGHT" />
    <uses-permission android:name="android.permission.health.WRITE_HEIGHT" />
    <uses-permission android:name="android.permission.health.READ_BODY_FAT" />
    <uses-permission android:name="android.permission.health.WRITE_BODY_FAT" />
    <uses-permission android:name="android.permission.health.READ_LEAN_BODY_MASS" />
    <uses-permission android:name="android.permission.health.WRITE_LEAN_BODY_MASS" />
    <uses-permission android:name="android.permission.health.READ_BASAL_METABOLIC_RATE" />
    <uses-permission android:name="android.permission.health.WRITE_BASAL_METABOLIC_RATE" />
    <uses-permission android:name="android.permission.health.READ_BONE_MASS" />
    <uses-permission android:name="android.permission.health.WRITE_BONE_MASS" />
    <uses-permission android:name="android.permission.health.READ_BODY_WATER_MASS" />
    <uses-permission android:name="android.permission.health.WRITE_BODY_WATER_MASS" />
    <uses-permission android:name="android.permission.health.READ_FLOORS_CLIMBED" />
    <uses-permission android:name="android.permission.health.WRITE_FLOORS_CLIMBED" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_ELEVATION_GAINED" />
    <uses-permission android:name="android.permission.health.READ_WHEELCHAIR_PUSHES" />
    <uses-permission android:name="android.permission.health.WRITE_WHEELCHAIR_PUSHES" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_SPEED" />
    <uses-permission android:name="android.permission.health.WRITE_SPEED" />
    <uses-permission android:name="android.permission.health.READ_POWER" />
    <uses-permission android:name="android.permission.health.WRITE_POWER" />
    <uses-permission android:name="android.permission.health.READ_STEPS_CADENCE" />
    <uses-permission android:name="android.permission.health.WRITE_STEPS_CADENCE" />
    <uses-permission android:name="android.permission.health.READ_CYCLING_PEDALING_CADENCE" />
    <uses-permission android:name="android.permission.health.WRITE_CYCLING_PEDALING_CADENCE" />
    <uses-permission android:name="android.permission.health.READ_PLANNED_EXERCISE" />
    <uses-permission android:name="android.permission.health.WRITE_PLANNED_EXERCISE" />
    <uses-permission android:name="android.permission.health.READ_HYDRATION" />
    <uses-permission android:name="android.permission.health.WRITE_HYDRATION" />
    <uses-permission android:name="android.permission.health.READ_NUTRITION" />
    <uses-permission android:name="android.permission.health.WRITE_NUTRITION" />
    <uses-permission android:name="android.permission.health.READ_MINDFULNESS" />
    <uses-permission android:name="android.permission.health.WRITE_MINDFULNESS" />

    <!-- Health Connect permissions - Phase 3 (requested from Vitals) -->
    <uses-permission android:name="android.permission.health.READ_BLOOD_PRESSURE" />
    <uses-permission android:name="android.permission.health.WRITE_BLOOD_PRESSURE" />
    <uses-permission android:name="android.permission.health.READ_OXYGEN_SATURATION" />
    <uses-permission android:name="android.permission.health.WRITE_OXYGEN_SATURATION" />
    <uses-permission android:name="android.permission.health.READ_RESPIRATORY_RATE" />
    <uses-permission android:name="android.permission.health.WRITE_RESPIRATORY_RATE" />
    <uses-permission android:name="android.permission.health.READ_BODY_TEMPERATURE" />
    <uses-permission android:name="android.permission.health.WRITE_BODY_TEMPERATURE" />
    <uses-permission android:name="android.permission.health.READ_VO2_MAX" />
    <uses-permission android:name="android.permission.health.WRITE_VO2_MAX" />
    <uses-permission android:name="android.permission.health.READ_BLOOD_GLUCOSE" />
    <uses-permission android:name="android.permission.health.WRITE_BLOOD_GLUCOSE" />
    <uses-permission android:name="android.permission.health.READ_SKIN_TEMPERATURE" />

    <!-- Health Connect permissions - Phase 4 (cycle tracking opt-in) -->
    <uses-permission android:name="android.permission.health.READ_MENSTRUATION" />
    <uses-permission android:name="android.permission.health.WRITE_MENSTRUATION" />
    <uses-permission android:name="android.permission.health.READ_OVULATION_TEST" />
    <uses-permission android:name="android.permission.health.WRITE_OVULATION_TEST" />
    <uses-permission android:name="android.permission.health.READ_CERVICAL_MUCUS" />
    <uses-permission android:name="android.permission.health.WRITE_CERVICAL_MUCUS" />
    <uses-permission android:name="android.permission.health.READ_BASAL_BODY_TEMPERATURE" />
    <uses-permission android:name="android.permission.health.WRITE_BASAL_BODY_TEMPERATURE" />
    <uses-permission android:name="android.permission.health.READ_INTERMENSTRUAL_BLEEDING" />
    <uses-permission android:name="android.permission.health.WRITE_INTERMENSTRUAL_BLEEDING" />
    <uses-permission android:name="android.permission.health.READ_SEXUAL_ACTIVITY" />
    <uses-permission android:name="android.permission.health.WRITE_SEXUAL_ACTIVITY" />

    <!-- Health Connect permissions - optional data access modes -->
    <uses-permission android:name="android.permission.health.READ_HEALTH_DATA_HISTORY" />
    <uses-permission android:name="android.permission.health.READ_HEALTH_DATA_IN_BACKGROUND" />

    <!-- =========================================================================
         Live activity recording (GPS + sensors + BLE) permissions.
         ========================================================================= -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!--
        Phone-to-phone Health Connect sync (bluetooth_sync_native) reuses
        BLUETOOTH_SCAN + BLUETOOTH_CONNECT above and additionally needs
        BLUETOOTH_ADVERTISE (API 31+) for ACTION_REQUEST_DISCOVERABLE, so the
        other phone can find this one. RFCOMM (Bluetooth Classic) is used
        deliberately over Wi-Fi: any TCP/UDP socket on Android requires the
        INTERNET permission, which this app never declares (see the offline-only
        block below). Bluetooth keeps the transfer peer-to-peer with no network.
    -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADVERTISE"
        tools:targetApi="s" />
    <!--
        Garmin watch onboarding (bluetooth_sync_native / CompanionDevices.kt).
        The companion association is what lets the OS keep this app's process
        alive while the watch is in range, so a FIT-file sync that runs for
        minutes is not killed halfway through. Both are install-time grants with
        no runtime prompt of their own — the user's consent IS the system
        "Allow OpenVitals to access <watch>?" dialog. Declining it is supported:
        the watch is bonded and syncs regardless, just without the priority
        boost. Same reasoning as the block above: plugin permissions must be
        declared by the installable app.
    -->
    <uses-permission android:name="android.permission.REQUEST_COMPANION_RUN_IN_BACKGROUND" />
    <!--
        Required by start/stopObservingDevicePresence, which is what actually
        makes the OS bind OpenVitalsCompanionDeviceService when the watch comes
        into range. Without it those calls throw SecurityException and the
        association exists but buys nothing.

        Deliberately NOT declared: REQUEST_COMPANION_USE_DATA_IN_BACKGROUND. It
        governs background NETWORK use, and this app ships no INTERNET
        permission at all, so asking for it would be meaningless.
    -->
    <uses-permission android:name="android.permission.REQUEST_OBSERVE_COMPANION_DEVICE_PRESENCE" />
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS" />

    <!-- Foreground service (flutter_foreground_task GPS recorder + geolocator). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Notifications + reminders (flutter_local_notifications, android_alarm_manager_plus).

         SCHEDULE_EXACT_ALARM lets hydration/mindfulness reminders fire at the time the
         user set rather than inside Android's inexact-alarm window (which on Android 14+
         was observed to be tens of minutes wide). It is the USER-GRANTABLE exact-alarm
         permission: broadly eligible, no core-function requirement, and NOT subject to
         Google Play's restricted-permission review. See
         docs/reference/exact-alarm-permission.md.

         We deliberately do NOT declare USE_EXACT_ALARM. That one is auto-granted but
         RESTRICTED — Play only allows it for apps whose core function IS an alarm clock,
         timer or calendar. Declaring it on a health dashboard risks the app being
         rejected or pulled. Never add it.

         Denied by default on Android 14+, so BatchZonedNotificationReminderScheduler
         consults canScheduleExactReminders() at schedule time and picks
         AndroidScheduleMode.inexactAllowWhileIdle (a Doze-surviving window) when the
         permission is absent — the reminder is never dropped, only made approximate. The
         reminder settings offer a button that opens the system screen to grant it. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- =========================================================================
         OpenVitals is OFFLINE-ONLY: the shipped (release) build declares NO
         INTERNET permission, matching the Kotlin source's no-network stance.
         RouteMapView defaults to an offline no-tile placeholder (no network
         raster fetch) so nothing in the app attempts a connection.
         NOTE: android/app/src/debug/ and src/profile/ still add INTERNET because
         the Flutter tool needs it for hot reload / breakpoints. That affects only
         debug/profile builds, never the release APK. We additionally strip any
         network-state permissions a dependency might contribute, mirroring the
         source manifest's `tools:node="remove"` guards.
         ========================================================================= -->
    <uses-permission
        android:name="android.permission.ACCESS_NETWORK_STATE"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.ACCESS_WIFI_STATE"
        tools:node="remove" />
    <uses-feature
        android:name="android.hardware.wifi"
        tools:node="remove" />

    <!-- Optional hardware; app remains installable on devices lacking these. -->
    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.sensor.accelerometer"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.sensor.proximity"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.sensor.stepdetector"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="false" />
    <!--
        CompanionDeviceManager (Garmin watch onboarding). NOT optional
        boilerplate: without this declaration `CompanionDeviceManager.associate`
        throws "Must declare uses-feature android.software.companion_device_setup
        in manifest to use this API" from the system service, so the association
        can never be offered. `required="false"` keeps the app installable on
        devices that lack companion support, where onboarding degrades to a
        plain bond that syncs fine without the background priority boost.
    -->
    <uses-feature
        android:name="android.software.companion_device_setup"
        android:required="false" />

    <!-- =========================================================================
         Package visibility queries (Android 11+).
         ========================================================================= -->
    <queries>
        <!-- Health Connect availability + permission rationale (health plugin). -->
        <package android:name="com.google.android.apps.healthdata" />
        <package android:name="com.android.vending" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
        <intent>
            <action android:name="android.health.connect.action.MANAGE_HEALTH_PERMISSIONS" />
        </intent>
        <intent>
            <action android:name="android.health.connect.action.HEALTH_HOME_SETTINGS" />
        </intent>
        <intent>
            <action android:name="androidx.health.ACTION_HEALTH_CONNECT_SETTINGS" />
        </intent>
        <intent>
            <action android:name="android.health.connect.action.MANAGE_HEALTH_DATA" />
        </intent>
        <intent>
            <action android:name="androidx.health.ACTION_MANAGE_HEALTH_DATA" />
        </intent>
        <!-- Text-to-speech engine discovery (flutter_tts voice guidance). -->
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
        <!-- Email intent for support / export. -->
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="mailto" />
        </intent>
        <!-- Flutter engine ProcessTextPlugin (from template). -->
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
    </queries>

    <application
        android:label="${appLabel}"
        android:name="${applicationName}"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <!-- Flutter's automatic deep linking is ON by default: it hands the
                 launching intent's data URI straight to the router as the initial
                 route. Every URI-carrying intent this activity receives is NOT a
                 go_router location — a home-widget tap
                 (`openvitals://widget?route=...`) and an "Open with" on a
                 .gpx/.fit (`content://...`) — so go_router failed them with
                 "no routes for location" before our own handlers ever ran.
                 Both are consumed explicitly instead (HomeWidgetLaunchBootstrap
                 via the home_widget plugin; RouteImportIntentBootstrap via the
                 route_import channel), so turn the automatic handling off. -->
            <meta-data
                android:name="flutter_deeplinking_enabled"
                android:value="false" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Health Connect permission-rationale deep link (Android 13-):
                 tapping the privacy-policy link in Health Connect opens the app.
                 The `health` plugin routes this to the Dart rationale screen. -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
            <!-- home_widget: allow a tapped widget to launch the app. -->
            <intent-filter>
                <action android:name="es.antonborri.home_widget.action.LAUNCH" />
            </intent-filter>
            <!-- NOTE: no APPWIDGET_CONFIGURE filter here, deliberately. This
                 activity is `singleTop`, so a configure intent arriving while the
                 app was running was delivered to the *running* instance via
                 onNewIntent: `main()` never re-ran (so the picker read a stale or
                 absent appWidgetId off the initial intent), and the activity had
                 never been started for result (so RESULT_OK reached nobody and the
                 launcher dropped the widget). Each configurable widget now has its
                 own dedicated configuration activity — see
                 HomeWidgetConfigureActivity.kt. -->

            <!-- "Open with" / "Share" a route file (.gpx/.kml/.kmz/.fit/.tcx) into the
                 activity-entry form. Mirrors the Kotlin manifest: one filter by
                 MIME type, one by filename suffix (many providers report route
                 files as `*/*` or octet-stream, so the suffix filter is the one
                 that actually fires in practice), and one for SEND/SEND_MULTIPLE.
                 The `*/*` filter is deliberately broad — MainActivity re-checks
                 the extension and ignores anything unsupported. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:mimeType="application/gpx" />
                <data android:mimeType="application/gpx+xml" />
                <data android:mimeType="application/vnd.google-earth.kml+xml" />
                <data android:mimeType="application/vnd.google-earth.kmz" />
                <data android:mimeType="application/vnd.google-earth.kmz+xml" />
                <data android:mimeType="application/vnd.ant.fit" />
                <data android:mimeType="application/vnd.garmin.fit" />
                <data android:mimeType="application/fit" />
                <data android:mimeType="application/x-fit" />
                <data android:mimeType="application/vnd.garmin.tcx+xml" />
                <data android:mimeType="application/tcx+xml" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:host="*" />
                <data android:mimeType="*/*" />
                <data android:pathPattern="/.*\\.gpx" />
                <data android:pathPattern="/.*\\.GPX" />
                <data android:pathPattern="/.*\\.kml" />
                <data android:pathPattern="/.*\\.KML" />
                <data android:pathPattern="/.*\\.kmz" />
                <data android:pathPattern="/.*\\.KMZ" />
                <data android:pathPattern="/.*\\.fit" />
                <data android:pathPattern="/.*\\.FIT" />
                <data android:pathPattern="/.*\\.tcx" />
                <data android:pathPattern="/.*\\.TCX" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <action android:name="android.intent.action.SEND_MULTIPLE" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="application/gpx" />
                <data android:mimeType="application/gpx+xml" />
                <data android:mimeType="application/vnd.google-earth.kml+xml" />
                <data android:mimeType="application/vnd.google-earth.kmz" />
                <data android:mimeType="application/vnd.google-earth.kmz+xml" />
                <data android:mimeType="application/vnd.ant.fit" />
                <data android:mimeType="application/vnd.garmin.fit" />
                <data android:mimeType="application/fit" />
                <data android:mimeType="application/x-fit" />
                <data android:mimeType="application/vnd.garmin.tcx+xml" />
                <data android:mimeType="application/tcx+xml" />
            </intent-filter>
        </activity>

        <!-- =====================================================================
             Home-widget configuration activities (ports of the Kotlin
             `HomeMetricWidgetConfigurationActivity` /
             `HomeQuickBeverageWidgetConfigurationActivity`). One per configurable
             widget, so the activity KNOWS what it is configuring and is genuinely
             `startActivityForResult`-ed by the launcher.

             Three attributes matter and none is incidental:
             * NO `launchMode` (i.e. `standard`): `singleTop` is precisely what
               broke the old MainActivity-hosted flow — Android would hand the
               configure intent to the already-running instance instead of starting
               a new, for-result activity.
             * `exported="false"`: the launcher never starts these itself; the
               AppWidget framework does, through a system-created IntentSender.
             * `excludeFromRecents="true"`: a modal, single-purpose activity has no
               business showing up as a task.
             ===================================================================== -->
        <activity
            android:name=".HomeMetricWidgetConfigureActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <meta-data
                android:name="flutter_deeplinking_enabled"
                android:value="false" />
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Shared by BOTH beverage widgets (the 2x1 and the 1x1 one-tap), exactly
             as Kotlin shared one configuration activity between them: the picker is
             identical, and the activity resolves which of the two providers is
             bound to the appWidgetId to know which receiver to push to. -->
        <activity
            android:name=".HomeQuickBeverageWidgetConfigureActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <meta-data
                android:name="flutter_deeplinking_enabled"
                android:value="false" />
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Health Connect permission-usage rationale (Android 14+). -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- flutter_foreground_task GPS recording service. Type list is a superset;
             the Dart ForegroundTaskOptions selects which type(s) to start with.
             Mirrors the Kotlin ActivityRecordingService (location|health|connectedDevice). -->
        <service
            android:name="com.pravera.flutter_foreground_task.service.ForegroundService"
            android:foregroundServiceType="location|health|connectedDevice|dataSync"
            android:exported="false" />

        <!-- bluetooth_sync_native: bound by the OS while an associated Garmin
             watch is in range. It runs no logic of its own — the BINDING is the
             point, because it elevates this process's priority so a multi-minute
             BLE file sync is not killed by the low-memory killer. `exported` and
             the BIND_COMPANION_DEVICE_SERVICE permission are both required by
             the platform contract: the system alone may bind it. API 31+; below
             that the OS simply never binds it. -->
        <service
            android:name="tech.mmarca.openvitals.bluetooth_sync_native.OpenVitalsCompanionDeviceService"
            android:exported="true"
            android:permission="android.permission.BIND_COMPANION_DEVICE_SERVICE"
            tools:targetApi="s">
            <intent-filter>
                <action android:name="android.companion.CompanionDeviceService" />
            </intent-filter>
        </service>

        <!-- flutter_local_notifications: scheduled + boot-persisted reminders and actions. -->
        <receiver
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationReceiver"
            android:exported="false" />
        <receiver
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationBootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>
        <receiver
            android:name="com.dexterous.flutterlocalnotifications.ActionBroadcastReceiver"
            android:exported="false" />

        <!-- android_alarm_manager_plus: now serves ONLY the periodic home-screen-widget
             refresh (alarm id 5003). Hydration/mindfulness reminders moved to
             flutter_local_notifications, whose ScheduledNotificationBootReceiver above
             re-arms them across reboot AND app update (MY_PACKAGE_REPLACED) — which the
             one-shot alarm could not, so a nightly install used to kill the reminder. -->
        <service
            android:name="dev.fluttercommunity.plus.androidalarmmanager.AlarmService"
            android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="false" />
        <receiver
            android:name="dev.fluttercommunity.plus.androidalarmmanager.AlarmBroadcastReceiver"
            android:exported="false" />
        <receiver
            android:name="dev.fluttercommunity.plus.androidalarmmanager.RebootBroadcastReceiver"
            android:enabled="false"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- home_widget: background callback receiver (updates widgets off the UI). -->
        <receiver
            android:name="es.antonborri.home_widget.HomeWidgetBackgroundReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="es.antonborri.home_widget.action.BACKGROUND" />
            </intent-filter>
        </receiver>

        <!-- =====================================================================
             Home-screen widgets (Glance). Dart pushes a snapshot into the shared
             `HomeWidgetPreferences` and the composables render it. The metric and
             the two quick-beverage widgets are additionally configurable per
             instance — each points `android:configure` at its OWN activity
             (HomeMetricWidgetConfigureActivity / HomeQuickBeverageWidgetConfigureActivity,
             declared above), because the metric catalog and the drink catalog both
             live in Dart. It must NOT be MainActivity: that is singleTop, so the
             configure intent was delivered to the already-running instance through
             onNewIntent, the appWidgetId came back stale (wrong picker), and the
             launcher never received RESULT_OK (the widget was never created). A tap on a beverage tile logs the
             drink through the HomeWidgetBackgroundReceiver declared above.
             ===================================================================== -->
        <receiver
            android:name=".features.homewidgets.HomeMetricWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/home_metric_widget_info" />
        </receiver>

        <receiver
            android:name=".features.homewidgets.HomeQuickBeverageWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/home_quick_beverage_widget_info" />
        </receiver>

        <receiver
            android:name=".features.homewidgets.HomeQuickBeverageOneTapWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/home_quick_beverage_one_tap_widget_info" />
        </receiver>

        <receiver
            android:name=".features.homewidgets.HomeDailyReadinessWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/home_daily_readiness_widget_info" />
        </receiver>

        <receiver
            android:name=".features.homewidgets.HomeBodyEnergyWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/home_body_energy_widget_info" />
        </receiver>

        <receiver
            android:name=".features.homewidgets.HomeTodayVitalsWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/home_today_vitals_widget_info" />
        </receiver>

        <!-- Status-bar icon for the activity-recording foreground service
             notification: the shared OpenVitals monochrome mark, matching every
             other notification. flutter_foreground_task resolves NotificationIcon
             by looking up an application <meta-data> whose android:resource is the
             drawable id; without it the notification falls back to the full-colour
             launcher icon and renders as a blank/placeholder square. -->
        <meta-data
            android:name="tech.mmarca.openvitals.ACTIVITY_RECORDING_ICON"
            android:resource="@drawable/ic_launcher_monochrome" />

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
</manifest>
